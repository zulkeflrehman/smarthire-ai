# SmartHire AI 2.0 — Environment Variables
# Copy this to .env and fill in the values.
# NEVER commit .env to Git.

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-replace-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank for SQLite (local dev)
# Set to Render PostgreSQL URL in production
DATABASE_URL=

# ── ML Settings ───────────────────────────────────────────────────────────────
USE_SEMANTIC_SCORING=True
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── LLM API (required for AI features) ───────────────────────────────────────
# Get a FREE key at: https://console.groq.com
# Free tier: 30 req/min, 6000 req/day — more than enough for demos
GROQ_API_KEY=your-groq-api-key-here

# Optional: Gemini fallback
# Get free key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key-here
