# SmartHire AI — Environment Variables
# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit real secrets.

# ── Django ────────────────────────────────────────────────────────────────────
# Generate a new key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank for SQLite (local dev).
# Set to Render PostgreSQL URL in production, e.g.:
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── ML / BERT settings ────────────────────────────────────────────────────────
# Set to False to skip BERT and use TF-IDF + Skill only (faster, lower RAM)
USE_SEMANTIC_SCORING=True
# all-MiniLM-L6-v2 → 80 MB download, fast on CPU
# all-mpnet-base-v2 → 420 MB download, slightly better accuracy
EMBEDDING_MODEL=all-MiniLM-L6-v2
